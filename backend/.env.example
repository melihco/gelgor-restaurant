# ──────────────────────────────────────────────
# SmartAgency Backend Configuration
# Copy to .env and fill in real values
# ──────────────────────────────────────────────

# App
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=change-me-to-a-random-64-char-string
INTERNAL_API_KEY=smartagency-internal-dev-key
# Yerel: Nexus /api/v1 (Ads, Analytics proxy) için true. Prod’da dışarıya Python açmayacaksanız false.
ENABLE_PUBLIC_API=true

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://nexus:nexus_dev_2024@localhost:5432/nexus_db

# Redis
REDIS_URL=redis://localhost:6379/0

# ──────────────────────────────────────────────
# Distributed orchestration (multi-tenant scaling)
# ──────────────────────────────────────────────
# PRODUCTION_ORCHESTRATOR: "apscheduler" (default, single-process) or "celery"
# (horizontally scalable). When "celery", run celery-worker + celery-beat and the
# in-process APScheduler production jobs (advance/drain/posts/cadence) are skipped.
PRODUCTION_ORCHESTRATOR=apscheduler
# Celery broker/result backend. Default derives from REDIS_URL (db 1 / db 2).
# CELERY_BROKER_URL=redis://localhost:6379/1
# CELERY_RESULT_BACKEND=redis://localhost:6379/2

# PRODUCTION_EXECUTOR: "http" (default, synchronous POST to Next.js) or "bullmq"
# (Python enqueues slot batches; a Next.js BullMQ worker executes + calls back).
PRODUCTION_EXECUTOR=http

# ──────────────────────────────────────────────
# LLM Providers — Model Seçimi
# ──────────────────────────────────────────────
#
# SEÇENEK A: OpenAI (Önerilen başlangıç)
# -----------------------------------------
# gpt-4o-mini  → Hızlı, ucuz, basit görevler için
# gpt-4o       → En güçlü OpenAI modeli — content + strateji için önerilen
# gpt-4o-mini içeriği gpt-4o ile override etmek için:
#   OPENAI_MODEL=gpt-4o-mini
#   OPENAI_CONTENT_MODEL=gpt-4o    ← content görevler için override
#
# ── AI model tier (Starter = düşük maliyet, ekran testleri) ───────────────
# starter | agency | premium — Next.js ile aynı: AI_MODEL_TIER
AI_MODEL_TIER=starter
# Starter varsayılanları (premium için OPENAI_MODEL=gpt-4o, LITE_STRUCTURAL_TASKS_ENABLED=false)
CREWAI_LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_CONTENT_MODEL=          # boş bırakırsan OPENAI_MODEL kullanılır
OPENAI_LITE_MODEL=gpt-4o-mini
LITE_STRUCTURAL_TASKS_ENABLED=true
LLM_MAX_TOKENS_CAP=8192

# SEÇENEK B: Anthropic Claude (En iyi brand voice + içerik kalitesi)
# -----------------------------------------
# claude-3-5-sonnet-20241022  → En iyi creative writing + brand voice
# claude-3-haiku-20240307     → Hızlı + ucuz, basit görevler için
# Geçiş için: CREWAI_LLM_PROVIDER=anthropic
#
# CREWAI_LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929
ANTHROPIC_MCP_MODEL=claude-sonnet-4-5-20250929

# Agent design skill — Visual Production Director
# AGENT_MCP_ENABLED=true
# ENABLE_VISUAL_PRODUCTION_DIRECTOR=true
#
# Local design MCP (./scripts/start-design-mcp.sh → port 8010)
# MCP_AUTH_TOKEN=smartagency-mcp-dev
# MCP_DESIGN_URL=http://127.0.0.1:8010/mcp
#
# Remote Anthropic connector (production — must be public HTTPS):
# MCP_SERVERS_JSON=[{"name":"smartagency-design","url":"https://your-host/mcp","authorization_token_env":"MCP_AUTH_TOKEN"}]

# CrewAI agent belleği — true yapılırsa ChromaDB ile geçmiş hafızası aktif olur.
# pip install chromadb gerekir. İlk çalışmada 2-3sn ek yük.
# Tenant learning service (kendi implementasyonumuz) zaten aktif — buna ek.
CREWAI_AGENT_MEMORY=false

# Tenant Learning — onaylanan/reddedilen içeriklerden öğrenme
TENANT_LEARNING_ENABLED=true
TENANT_LEARNING_MAX_EXAMPLES=5

# CrewAI ayrıntılı konsol; sıralı görevlerde ara adımlar "In Progress" gösterebilir — gerekiyorsa true
CREW_VERBOSE=false

# Durable Production Factory — feed üretimi tek-atış legacy yerine kalıcı per-slot
# kuyruğa alınır. Varsayılan (boş/false): fabrika kuyruğa alamazsa sessizce legacy
# inline üretime düşer (mevcut davranış). true yapılırsa enqueue hatası legacy'ye
# düşmeden açık bir üretim hatası olarak yüzeye çıkar (deterministik, legacy emekliye
# ayrılmaya hazır olunca açın).
# PRODUCTION_FACTORY_REQUIRE=false

# ── AI maliyet azaltma (Faz 3) — flag arkasında, varsayılan = mevcut davranış ──
# Faz 3.2: yapısal/planlama görevlerini (content_calendar, visual_design_cards,
# feed_cohesion_review) ucuz modele (gpt-4o-mini) yönlendir. content_ideation ve
# content_strategy tam modelde kalır (yaratıcı iş). Varsayılan false → değişiklik yok.
# LITE_STRUCTURAL_TASKS_ENABLED=false
# Faz 3.3: LLM tamamlama token tavanı (kaçak JSON çıktısını engeller). 0 = kapalı
# (mevcut davranış). Açarken şema boyutunun rahatça üstünde tutun (ör. 8192).
# LLM_MAX_TOKENS_CAP=0

# Optional: local model via Ollama or LM Studio
# Set CREWAI_LLM_PROVIDER=ollama to switch
CREWAI_LLM_PROVIDER=openai
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# ──────────────────────────────────────────────
# External Integrations
# ──────────────────────────────────────────────

# Google Business / Reviews
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_BUSINESS_ACCOUNT_ID=

# Meta / Instagram
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=

# Google Ads
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=

# Google Analytics 4
GA4_PROPERTY_ID=
GA4_CREDENTIALS_JSON=

# Google Search Console
SEARCH_CONSOLE_SITE_URL=

# Google OAuth (shared across Google services)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:5050/api/integrations/google/callback

# Mock mode (set to false to use real APIs)
SMART_AGENCY_MOCK=true

# Crew tools: fake Google reviews / Instagram insights fixtures (default off — empty / not_connected)
SMART_AGENCY_FAKE_TOOL_DATA=false

# ──────────────────────────────────────────────
# Image Pipeline
# ──────────────────────────────────────────────

# Provider: openai_dalle | stability | replicate | none
IMAGE_PROVIDER=none
STABILITY_API_KEY=
REPLICATE_API_TOKEN=

# Asset storage
ASSET_STORAGE_PATH=./storage/assets

# ──────────────────────────────────────────────
# Token billing (SA Kredi) — müşteri fiyatlandırması
# ──────────────────────────────────────────────
# Fiyat = API maliyeti × TOKEN_MARKUP_MULTIPLIER (varsayılan 10×)
TOKEN_BILLING_ENABLED=true
TOKEN_MARKUP_MULTIPLIER=10
TOKEN_PROFIT_MARGIN_PERCENT=40
TOKEN_USD_VALUE=0.01
TOKEN_TRY_RATE=0.35
TOKEN_MONTHLY_GRANT=25000
TOKEN_DISPLAY_NAME=SA Kredi
# Daily API spend cap per workspace (auto-produce + missions). $5 ≈ 2 full mission runs.
WORKSPACE_DAILY_BUDGET_USD=50
AUTO_CONTENT_MAX_DAILY=12
# Günlük kota varsayılan kapalı; limit için AUTO_PRODUCE_BYPASS_LIMITS=false
AUTO_PRODUCE_BYPASS_LIMITS=true

# ── Production automation (dev: keep manual-only to avoid fal.ai spend) ───────
# false = mission graph never auto-triggers Feed / fal.ai (manual kick only)
AUTO_FEED_PRODUCTION_ENABLED=false
# false = no scheduler mission proposals (semi-auto, seasonal, opportunity, special days)
AUTO_MISSION_PROPOSAL_ENABLED=false
# false = no fully autonomous propose+approve+execute loop (every 6h)
AUTO_CONTENT_ENABLED=false

# ──────────────────────────────────────────────
# CORS
# ──────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3002,http://localhost:3000
