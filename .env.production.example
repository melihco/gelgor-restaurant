# SmartAgency production/staging environment template

APP_ENV=production
APP_DEBUG=false
ASPNETCORE_ENVIRONMENT=Production
DEPLOYMENT_ENVIRONMENT=production

POSTGRES_USER=nexus
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_DB=nexus_db

INTERNAL_API_KEY=replace-with-random-internal-key
ORCHESTRATION_TIMEOUT_SECONDS=300
ACTION_EXECUTION_MODE=dry-run
ACTION_EXECUTION_TIMEOUT_SECONDS=90

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

QDRANT_ENABLED=true
QDRANT_API_KEY=replace-with-qdrant-key
QDRANT_COLLECTION=brand_memory
QDRANT_VECTOR_SIZE=1536

GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://api.example.com/api/integrations/google/callback

FRONTEND_BASE_URL=https://app.example.com
NEXT_PUBLIC_API_URL=https://api.example.com
NEXT_PUBLIC_SIGNALR_URL=https://api.example.com

DEMO_TENANT_ID=00000000-0000-0000-0000-000000000001
DEMO_USER_ID=00000000-0000-0000-0000-000000000001
DEMO_OFFICE_ID=00000000-0000-0000-0000-000000000002

RATE_LIMIT_PER_MINUTE=120
