# Smart Agency — Railway environment variables (copy to each service in Railway dashboard)
# Reference: docs/railway-deploy.md

# ── Shared secrets (generate once, same value on api + web + backend) ──
INTERNAL_API_KEY=replace-with-openssl-rand-hex-32

# ── Postgres plugin (Railway → Variables → reference on api + backend) ──
# .NET API:
# ConnectionStrings__DefaultConnection=${{Postgres.DATABASE_URL}}
# Or explicit (SSL required on Railway):
# ConnectionStrings__DefaultConnection=Host=${{Postgres.PGHOST}};Port=${{Postgres.PGPORT}};Database=${{Postgres.PGDATABASE}};Username=${{Postgres.PGUSER}};Password=${{Postgres.PGPASSWORD}};SSL Mode=Require;Trust Server Certificate=true

# Python backend (Railway injects DATABASE_URL — auto-converted to asyncpg in config.py):
# DATABASE_URL=${{Postgres.DATABASE_URL}}

# ── Redis (optional; api) ──
# ConnectionStrings__Redis=${{Redis.REDIS_URL}}

# ── Public URLs (set after first deploy — use Railway *.up.railway.app domains) ──
FRONTEND_BASE_URL=https://YOUR-WEB.up.railway.app
NEXT_PUBLIC_API_URL=https://YOUR-API.up.railway.app
NEXT_PUBLIC_SIGNALR_URL=https://YOUR-API.up.railway.app
BACKEND_ORIGIN=https://YOUR-API.up.railway.app
NEXTJS_INTERNAL_URL=https://YOUR-WEB.up.railway.app
CREW_BACKEND_URL=https://YOUR-CREW.up.railway.app

# ── Web service ──
NEXT_PUBLIC_USE_DEMO_CONTEXT=false
NODE_ENV=production
AUTO_PRODUCE_BYPASS_LIMITS=false
AUTO_PRODUCE_GALLERY_ONLY=true

# ── API service ──
ASPNETCORE_ENVIRONMENT=Production
OrchestrationService__BaseUrl=https://YOUR-CREW.up.railway.app
OrchestrationService__ApiKey=${INTERNAL_API_KEY}
OrchestrationService__UseDevMock=false
Cors__AllowedOrigins__0=https://YOUR-WEB.up.railway.app
Frontend__BaseUrl=https://YOUR-WEB.up.railway.app
GOOGLE_OAUTH_REDIRECT_URI=https://YOUR-API.up.railway.app/api/integrations/google/callback

# ── Crew backend (internal — do not expose publicly if possible) ──
APP_ENV=production
APP_DEBUG=false
ENABLE_PUBLIC_API=false
INTERNAL_API_KEY=${INTERNAL_API_KEY}
OPENAI_API_KEY=
APIFY_API_KEY=
NEXUS_API_URL=https://YOUR-API.up.railway.app
NEXTJS_INTERNAL_URL=https://YOUR-WEB.up.railway.app
CORS_ORIGINS=https://YOUR-WEB.up.railway.app

# ── Media / AI (web + api as needed) ──
# OPENAI_API_KEY=
# FAL_API_KEY=
# RUNWAY_API_SECRET=
# R2_BUCKET_NAME=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_PUBLIC_URL=
