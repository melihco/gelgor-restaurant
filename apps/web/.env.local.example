# ─────────────────────────────────────────────────────────────
# Smart Agency OS — Environment Variables
# Copy this file to .env.local and fill in your secrets
# ─────────────────────────────────────────────────────────────

# ── Nexus .NET API (REST) ────────────────────────────────────
# Next.js dev: http://localhost:3000 (`npm run dev` bu portu kullanır)
# Tarayıcıya direkt bağlanmak yerine geliştirme ortamında Next proxy kullanılıyorsa
# NEXT_PUBLIC_BROWSER_API_PROXY=false yazarak kapatabilirsiniz.
# Yerel dotnet genelde 5050; Docker API 5000 ise burayı 5000 yapın (macOS’ta 5000 sık AirPlay’dir).
NEXT_PUBLIC_API_URL=http://127.0.0.1:5050
# Rewrite hedefi (next.config.ts) — NEXT_PUBLIC_API_URL ile aynı olabilir
BACKEND_ORIGIN=http://127.0.0.1:5050

# ── Örnek: demo bağlamı ─────────────────────────────────────
# NEXT_PUBLIC_USE_DEMO_CONTEXT=true

# ── Mobile: müşteri vs ajans operasyon paneli ───────────────
# Varsayılan (unset/false): müşteriye iç ekranlar gizli (Agents, AI Activity, Reels Studio…)
# true: tüm operasyon menüleri görünür (ajans ekibi için)
# NEXT_PUBLIC_MOBILE_OPERATOR_MODE=true

# ── Runway AI Video Generation ────────────────────────────────
# Get your key at https://dev.runwayml.com
RUNWAY_API_SECRET=your_runway_api_secret_here
# Set false to skip Runway in auto-produce (reels fail gracefully)
AUTO_PRODUCE_RUNWAY=true

# Model: gen4.5 (image-to-video) or gen4_turbo (text or image-to-video)
RUNWAY_MODEL=gen4_turbo

# API version — do not change unless Runway releases a new version
RUNWAY_API_VERSION=2024-11-06

# Default video duration in seconds (5 or 10 only for Gen 4.5/4 Turbo)
RUNWAY_DEFAULT_DURATION=10

# Default output ratio for Reels (portrait 9:16 = 720:1280)
# Options: 720:1280 | 832:1104 | 672:1584
RUNWAY_DEFAULT_RATIO=720:1280

# Task wait timeout in milliseconds (Runway generation can take 60-120s)
RUNWAY_TIMEOUT_MS=120000

# ── OpenAI (image generation for previews) ────────────────────
OPENAI_API_KEY=your_openai_key_here
SMART_AGENCY_IMAGE_PROVIDER=flux
FAL_API_KEY=your_fal_api_key_here
SMART_AGENCY_IMAGE_MODEL=gpt-image-1
SMART_AGENCY_IMAGE_QUALITY=high

# ── Auto Produce budget (Mission → Feed) ─────────────────────
# Python crew .env: WORKSPACE_DAILY_BUDGET_USD=50, AUTO_CONTENT_MAX_DAILY=12
# AUTO_PRODUCE_DAILY_BUDGET_USD=50
# Pilot: günlük USD + parça + Runway limitlerini kapat (prod öncesi false yapın)
AUTO_PRODUCE_BYPASS_LIMITS=true
# AUTO_PRODUCE_MAX_DAILY=500
# MISSION_AUTO_PRODUCE_MAX_PER_RUN=24
# AUTO_PRODUCE_MAX_REELS_DAILY=15

# ── Auto Produce visual safety ────────────────────────────────
# true: Feed production uses only real gallery photos; no scratch image generation.
AUTO_PRODUCE_GALLERY_ONLY=true
# false (default): do NOT AI-edit venue photos. Set true only for experiments.
AUTO_PRODUCE_SUBTLE_ENHANCE=false
# true (default): mekan/galeri fotoğrafları images.edit ile ASLA değiştirilmez.
# Metin overlay için Sharp+SVG kullanılır. Kapatmak: VENUE_PHOTO_PRESERVE=false
VENUE_PHOTO_PRESERVE=true

# Experimental: Crew Visual Production Director before auto-produce (global dev override)
# Per-tenant: Brand Hub → Ayarlar → "Crew görsel direktör" (enable_visual_production_director)
# ENABLE_VISUAL_PRODUCTION_DIRECTOR=false

# ── Canva Connect API (KAPALI — ürün politikası) ─────────────
# Smart Agency Canva kullanmaz. Üretim: Remotion (story) + ajans SVG poster (feed).
# CANVA_ENABLED ve NEXT_PUBLIC_CANVA_ENABLED varsayılan false; açmak için explicit true gerekir.
# CANVA_ENABLED=false
# NEXT_PUBLIC_CANVA_ENABLED=false
#
# Aşağıdaki değişkenler yalnızca yerel Canva denemeleri içindir (production'da kullanılmaz):
# Redirect URL must match the Canva Developer Portal entry exactly (scheme, host, path).
# Paths supported by this app: /api/canva/oauth/callback (default) or /api/auth/callback (alias).
# By default, /api/canva/oauth/login uses the request host for redirect_uri (so localhost works even
# if CANVA_REDIRECT_URI is stale). Set CANVA_REDIRECT_URI_USE_ENV=true to always use CANVA_REDIRECT_URI.
# If you open the app via ngrok but want Canva to redirect to localhost, set:
# CANVA_OAUTH_PUBLIC_REDIRECT_URI=http://localhost:3000/api/canva/oauth/callback
#
# HTTPS + Canva: use ngrok to port 3000 — Terminal A: `npm run dev`  Terminal B: `npm run tunnel:3000`
# Then Terminal C: `npm run canva:ngrok-env` and paste the printed CANVA_* lines here (and in Canva portal).
# If the ngrok URL changes, re-run canva:ngrok-env. Add the same https origin to Nexus `Cors:AllowedOrigins`
# when calling the .NET API from the ngrok-hosted Next app.
#
# ngrok (ERR_NGROK_3200): tunnel must stay running while you test.
#
CANVA_CLIENT_ID=your_canva_client_id_here
CANVA_CLIENT_SECRET=your_canva_client_secret_here
# Örnek yerel: CANVA_APP_ORIGIN=http://localhost:3000
# CANVA_REDIRECT_URI=http://localhost:3000/api/canva/oauth/callback
# Örnek HTTPS (ngrok): set all three from `npm run canva:ngrok-env` output:
# CANVA_REDIRECT_URI_USE_ENV=true
CANVA_APP_ORIGIN=https://your-ngrok-domain.ngrok-free.dev
CANVA_REDIRECT_URI=https://your-ngrok-domain.ngrok-free.dev/api/canva/oauth/callback
CANVA_SCOPES=asset:read asset:write brandtemplate:content:read brandtemplate:meta:read design:content:read design:content:write design:meta:read profile:read
# local (dev default) or nexus (stores Canva token through Nexus IntegrationConnection)
CANVA_TOKEN_STORAGE=local

# ── Mertcafe / Instagram publish (tenant-scoped; mobile Feed → Onayla) ──
# MERTCAFE_BASE_URL=https://web-production-02d278.up.railway.app
# Primary store: brand_theme per tenant (mertcafe_api_key, mertcafe_instagram_account_id).
# UI: Marka → Ayarlar → "Bu tenant için Mertcafe kaydı oluştur" calls POST /api/mertcafe/provision
#
# Ops fallback maps (JSON, workspace UUID = Nexus tenantId):
# MERTCAFE_WORKSPACE_API_KEYS={"5feb36f7-def7-4b4a-834f-353457de57bf":"api-key-for-kacta"}
# MERTCAFE_WORKSPACE_INSTAGRAM_ACCOUNTS={"5feb36f7-def7-4b4a-834f-353457de57bf":"6a200e8e2b2567671aae"}
#
# Dev only — share one global key across tenants missing theme key (NOT for production):
# MERTCAFE_ALLOW_GLOBAL_FALLBACK=true
# MERTCAFE_API_KEY=shared_dev_key_only
# Legacy global account id (scripts only; tenants do NOT read this):
# MERTCAFE_INSTAGRAM_ACCOUNT_ID=
